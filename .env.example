# IBM App ID configuration
# Get these from your App ID service credentials on IBM Cloud
VITE_APPID_CLIENT_ID=your-appid-client-id-here
VITE_APPID_DISCOVERY_ENDPOINT=https://us-south.appid.cloud.ibm.com/oauth/v4/YOUR_TENANT_ID/.well-known/openid-configuration

# CMG (CogBot Membership Gateway) API base URL
VITE_CMG_API=http://localhost:3001
# Namespace to pass when validating membership (matches role definitions in Cloudant)
VITE_CMG_NAMESPACE=bab
