# cogbot-membership-website-template — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# IBM App ID (authentication)
# Get these from your App ID service instance on IBM Cloud
VITE_APPID_CLIENT_ID=your-appid-client-id
VITE_APPID_OAUTH_SERVER_URL=https://us-south.appid.cloud.ibm.com/oauth/v4/YOUR_TENANT_ID

# CMG — CogBot Membership Gateway
# The URL of your CMG instance
VITE_CMG_URL=https://your-cmg.example.com
# Namespace for membership role filtering (must match Cloudant role definitions)
VITE_SITE_NAMESPACE=your-namespace

# CogBot Access Manager (CAM)
# The base URL of your CAM service (no trailing slash)
VITE_COGBOT_HOST=https://your-cam-service.example.com
# The CogBot ID to use for this site
VITE_COGBOT_ID=your-cogbot-id

# Optional. "path" (default) or "hash".
# Use "hash" on hosts that don't do SPA fallback (Lovable *.lovable.app,
# GitHub Pages without 404.html hack). Affects router type and
# OAuth redirect URI shape.
# VITE_ROUTER_MODE=hash
